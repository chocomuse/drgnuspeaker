[Unit]
Description=Drgnu Jetson AI Speaker
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=jetson
WorkingDirectory=/home/jetson/Drgnu/jetson_speaker
EnvironmentFile=/home/jetson/Drgnu/jetson_speaker/.env
ExecStart=/home/jetson/Drgnu/jetson_speaker/.venv/bin/python -m drgnu_speaker.main
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target


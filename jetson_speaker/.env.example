DRGNU_BASE_URL=https://aidrgnu.com/
DRGNU_API_KEY=replace-with-server-api-key
DRGNU_DEVICE_ID=jetson-nano-dev-001
DRGNU_DEVICE_NAME=Drgnu Jetson Speaker
DRGNU_DEVICE_TOKEN=
DRGNU_DEVICE_TOKEN_PATH=.device-token
DRGNU_PAIRING_ENABLED=false
DRGNU_PAIRING_POLL_SECONDS=3
DRGNU_LOCAL_PAIRING_ENABLED=true
DRGNU_LOCAL_PAIRING_PORT=8765
DRGNU_LOCAL_PAIRING_SERVICE_TYPE=_drgnu-speaker._tcp.local.
DRGNU_SETTINGS_SYNC_ENABLED=true
DRGNU_SETTINGS_SYNC_SECONDS=30
DRGNU_SESSION_ID=test_user_001
DRGNU_WAKE_MODE=keyboard
DRGNU_WAKE_MODEL_PATH=models/vosk-model-small-ko-0.22
DRGNU_WAKE_TIMEOUT_SECONDS=0
DRGNU_RECORD_SECONDS=7
DRGNU_SAMPLE_RATE=16000
DRGNU_CHANNELS=1
DRGNU_TTS_COMMAND=spd-say
DRGNU_PTT_GPIO_PIN=
DRGNU_LED_GPIO_PIN=
